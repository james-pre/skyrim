{
	"name": "skyrim-edit",
	"version": "1.0.0",
	"description": "A best-effort save file viewer and editor for Skyrim (Special Edition)",
	"license": "GPL-3.0-or-later",
	"author": "James Prevett <jp@jamespre.dev>",
	"type": "module",
	"main": "dist/index.js",
	"bin": "dist/main.js",
	"dependencies": {
		"@types/lz4": "^0.6.4",
		"@types/node": "^25.0.6",
		"lz4": "^0.6.5",
